<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- API Key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tavily API Key"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="tvly-your-key-here"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp"/>

        <!-- Auto Mode -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAutoMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto Mode (Recommended)"
            android:textStyle="bold"
            android:checked="true"
            android:layout_marginBottom="8dp"/>

        <!-- Manual Settings -->
        <LinearLayout
            android:id="@+id/manualSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search Depth"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <RadioGroup
                android:id="@+id/rgSearchDepth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rbBasic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basic"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rbAdvanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Advanced"/>
                <RadioButton
                    android:id="@+id/rbFast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fast"/>
                <RadioButton
                    android:id="@+id/rbUltraFast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ultra Fast"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Results"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <RadioGroup
                android:id="@+id/rgMaxResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"/>
                <RadioButton
                    android:id="@+id/rb15"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15"/>
                <RadioButton
                    android:id="@+id/rb20"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20"/>
            </RadioGroup>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIncludeAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include AI Answer"
                android:checked="true"
                android:layout_marginTop="16dp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIncludeRawContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include Raw Content"
                android:layout_marginTop="8dp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIncludeImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include Images"
                android:layout_marginTop="8dp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIncludeImageDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include Image Descriptions"
                android:layout_marginTop="8dp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIncludeFavicon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include Favicons"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default Topic"
                android:layout_marginTop="16dp"/>
            <Spinner
                android:id="@+id/spinnerTopic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time Range"
                android:layout_marginTop="8dp"/>
            <Spinner
                android:id="@+id/spinnerTimeRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Country Code"
                android:layout_marginTop="8dp"/>
            <EditText
                android:id="@+id/etCountry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="us, gb, etc."/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Include Domains (comma separated)"
                android:layout_marginTop="16dp"/>
            <EditText
                android:id="@+id/etIncludeDomains"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="example.com,news.com"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exclude Domains (comma separated)"
                android:layout_marginTop="8dp"/>
            <EditText
                android:id="@+id/etExcludeDomains"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="spam.com,bad.com"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset to Defaults"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
